    "@jest/types": "^29.5.0",
    "@types/faker": "^5.5.9",
    "@types/jest": "^29.5.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-prettier": "^5.5.5",
    "faker": "^5.5.3",
    "husky": "^7.0.4",
    "jest": "^29.7.0",
    "jest-extended": "^1.2.0",
    "minimatch": "10.2.2",
    "prettier": "^2.5.1",
    "semantic-release": "^25.0.3",
    "test-exclude": "^8.0.0",
    "ts-jest": "^29.4.6",
