{
  "name": "@yosnightfly/electra-smart-js-client",
  "version": "1.0.3",
  "description": "Electra Smart JS Client",
  "files": [
    "lib"
  ],
  "bin": {
    "electra-smart-js-client": "./lib/index.js"
  },
  "main": "lib/index.js",
  "typings": "lib/index.d.ts",
  "scripts": {
    "prepare": "husky install",
    "build": "rm -rf lib && tsc -p tsconfig.build.json",
